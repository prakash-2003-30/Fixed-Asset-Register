# PostgreSQL connection used by Prisma
DATABASE_URL="postgresql://far_user:far_password@localhost:5432/far_db?schema=public"

# API
PORT=4000
NODE_ENV=development

# Auth
JWT_SECRET="replace-with-a-long-random-string"
JWT_EXPIRES_IN="8h"

# CORS (frontend origin); use * for local dev
CORS_ORIGIN="*"

# Branding shown on exports / reports
COMPANY_NAME="HIKEHEALTH GS PRIVATE LIMITED"
REPORT_TITLE="Fixed Asset Register"
